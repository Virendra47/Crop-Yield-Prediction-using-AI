@model CropYieldPredictor.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="d-flex justify-content-center align-items-center py-5" style="min-height: 80vh;">
    <div class="agri-card shadow-lg" style="width: 100%; max-width: 450px;">
        <div class="agri-card-header text-center position-relative">
            <div class="text-center mb-3">
                <img src="/images/logo.jpg" alt="CropPredict AI Logo" class="rounded-circle border border-success shadow-lg" style="height: 75px; width: 75px; object-fit: cover; box-shadow: 0 0 20px rgba(16, 185, 129, 0.35);">
            </div>
            <h2 class="text-white fw-extrabold mb-1"><i class="bi bi-shield-lock-fill text-success me-2"></i>Sign In</h2>
            <p class="text-white-50 small">Access the AI Crop Yield Prediction Engine</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success bg-success-subtle text-success border-success text-center py-2" role="alert">
                <i class="bi bi-patch-check-fill me-1"></i> @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <!-- Username Field -->
            <div class="mb-4">
                <label asp-for="Username" class="form-label text-success fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-success text-success"><i class="bi bi-person-fill"></i></span>
                    <input asp-for="Username" class="form-control bg-dark text-white border-success" placeholder="Enter username..." />
                </div>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <!-- Password Field -->
            <div class="mb-4">
                <label asp-for="Password" class="form-label text-success fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-success text-success"><i class="bi bi-key-fill"></i></span>
                    <input asp-for="Password" class="form-control bg-dark text-white border-success" placeholder="Enter password..." />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- Remember Me & Actions -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input bg-dark border-success" />
                    <label asp-for="RememberMe" class="form-check-label text-white-50 small"></label>
                </div>
            </div>

            <button type="submit" class="btn btn-agri w-100 py-2.5 mb-3"><i class="bi bi-box-arrow-in-right me-1"></i>Sign In</button>

            <div class="text-center text-white-50 small mt-3">
                New to AgriPredict? <a asp-action="Register" class="text-success fw-bold text-decoration-none ms-1">Create an Account</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
