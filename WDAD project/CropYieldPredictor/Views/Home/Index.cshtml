@model CropYieldPredictor.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Agricultural Intelligence Dashboard";
    
    // Find best crop yielding
    string bestCrop = "";
    float maxYield = -1f;
    foreach(var item in Model.CropYields)
    {
        if(item.Value > maxYield)
        {
            maxYield = item.Value;
            bestCrop = item.Key;
        }
    }
}

<div class="container py-4">
    <!-- Beautiful Agricultural Widescreen Hero Banner -->
    <div class="agri-hero-banner mb-5 position-relative overflow-hidden shadow-lg border border-success border-opacity-20" style="background: linear-gradient(180deg, rgba(5, 19, 7, 0.4) 0%, rgba(26, 20, 5, 0.7) 100%), url('/images/agri_banner.png') no-repeat center center; background-size: cover; min-height: 280px; border-radius: 24px;">
        <div class="agri-hero-overlay d-flex align-items-center p-4 p-md-5 w-100 h-100" style="backdrop-filter: brightness(0.9);">
            <div class="row w-100 align-items-center">
                <div class="col-lg-7 text-white text-shadow mb-4 mb-lg-0">
                    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                        <img src="/images/logo.jpg" alt="CropPredict AI Logo" class="rounded-4 border border-success shadow border-2 glowing-logo" style="height: 80px; width: 80px; object-fit: cover; background-color: rgba(0,0,0,0.4);">
                        <div>
                            <span class="badge bg-success-glow text-success fw-bold px-3 py-2 border border-success border-opacity-50"><i class="bi bi-cpu-fill text-success-light me-1"></i>ML.NET Core AI Engine</span>
                            <h1 class="display-5 fw-extrabold mb-0 font-serif text-white header-sway" style="letter-spacing: -1px; margin-top: 5px;">
                                🌾 AgriPredict <span class="text-gradient-gold">Intelligence 🌤️</span>
                            </h1>
                        </div>
                    </div>
                    <p class="lead text-light mb-0 opacity-90">Precision farming crop optimization powered by real-time location climatology analytics & machine learning.</p>
                </div>
                <div class="col-lg-5">
                    <div class="search-glass-card p-4 rounded-4 shadow" style="background: rgba(11, 19, 10, 0.75); backdrop-filter: blur(20px); border: 1px solid rgba(245, 158, 11, 0.2); border-radius: 20px;">
                        <form asp-action="Index" method="post" class="d-flex flex-column gap-3">
                            <input type="hidden" name="actionType" value="search" />
                            <input type="hidden" asp-for="Rainfall" />
                            <input type="hidden" asp-for="Temperature" />
                            <input type="hidden" asp-for="Nitrogen" />
                            <input type="hidden" asp-for="Phosphorus" />
                            <input type="hidden" asp-for="Potassium" />
                            <input type="hidden" asp-for="Fertilizer" />
                            
                            <label class="text-white small fw-bold text-uppercase" style="letter-spacing: 0.5px;"><i class="bi bi-geo-alt-fill text-warning me-1"></i>Target Farm Location</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-dark border-success border-opacity-30 text-success"><i class="bi bi-search"></i></span>
                                <input asp-for="LocationQuery" class="form-control bg-dark text-white border-success border-opacity-30" placeholder="Enter Region, State or City..." style="border-radius: 0 10px 10px 0;" />
                            </div>
                            <button type="submit" class="btn btn-agri w-100"><i class="bi bi-search me-1"></i>Fetch Climate Profile</button>
                            <div class="text-white-50 small mt-1 d-flex justify-content-between align-items-center">
                                <span class="text-white-75">Showing: <strong>@Model.ResolvedLocation, @Model.Country</strong></span>
                                <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-50"><i class="bi bi-check2-circle me-1"></i>Active</span>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <form asp-action="Index" method="post" id="nutrientForm">
        <input type="hidden" name="actionType" value="nutrients" />
        <input type="hidden" asp-for="LocationQuery" />
        <input type="hidden" asp-for="ResolvedLocation" />
        <input type="hidden" asp-for="Country" />

        <div class="dashboard-grid">
            
            <!-- Left Panel: Environmental & Soil Nutrients -->
            <div class="d-flex flex-column gap-4">
                
                <!-- Weather API Metrics Card -->
                <div class="agri-card">
                    <div class="agri-card-header d-flex justify-content-between align-items-center">
                        <h4 class="m-0 text-success"><i class="bi bi-cloud-sun me-2"></i>🌦️ Climatology & Weather Metrics</h4>
                        <span class="badge bg-success-subtle text-success border border-success"><i class="bi bi-calendar-event me-1"></i>@DateTime.Now.Year Season</span>
                    </div>
                    
                    <div class="d-flex flex-column gap-3">
                        <div class="weather-widget">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small text-uppercase fw-bold">🌧️ Annual Rainfall</div>
                                    <div class="weather-val">@Model.Rainfall.ToString("0") <span class="fs-6 text-white-50">mm</span></div>
                                </div>
                                <div class="fs-1 text-info"><i class="bi bi-cloud-rain-heavy-fill"></i></div>
                            </div>
                            <!-- Hidden input to bind custom/API rainfall values -->
                            <input type="range" asp-for="Rainfall" min="300" max="1500" class="custom-range mt-3 d-none" />
                        </div>

                        <div class="weather-widget">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small text-uppercase fw-bold">🌡️ Avg Temperature</div>
                                    <div class="weather-val">@Model.Temperature.ToString("0.0") <span class="fs-6 text-white-50">°C</span></div>
                                </div>
                                <div class="fs-1 text-warning"><i class="bi bi-thermometer-sun"></i></div>
                            </div>
                            <!-- Hidden input to bind custom/API temperature values -->
                            <input type="range" asp-for="Temperature" min="10" max="45" class="custom-range mt-3 d-none" />
                        </div>
                    </div>
                </div>

                <!-- Soil Nutrients Sliders Card -->
                <div class="agri-card">
                    <div class="agri-card-header">
                        <h4 class="m-0 text-success"><i class="bi bi-sliders me-2"></i>🧪 Soil & Nutrient Simulator</h4>
                    </div>

                    <!-- Nitrogen Slider -->
                    <div class="slider-container">
                        <div class="slider-label">
                            <span>🟢 Nitrogen (N)</span>
                            <span class="text-success"><span id="val-Nitrogen">@Model.Nitrogen</span> kg/ha</span>
                        </div>
                        <input type="range" asp-for="Nitrogen" min="0" max="200" step="1" class="custom-range slider-input" />
                    </div>

                    <!-- Phosphorus Slider -->
                    <div class="slider-container">
                        <div class="slider-label">
                            <span>🔵 Phosphorus (P)</span>
                            <span class="text-success"><span id="val-Phosphorus">@Model.Phosphorus</span> kg/ha</span>
                        </div>
                        <input type="range" asp-for="Phosphorus" min="0" max="200" step="1" class="custom-range slider-input" />
                    </div>

                    <!-- Potassium Slider -->
                    <div class="slider-container">
                        <div class="slider-label">
                            <span>🟡 Potassium (K)</span>
                            <span class="text-success"><span id="val-Potassium">@Model.Potassium</span> kg/ha</span>
                        </div>
                        <input type="range" asp-for="Potassium" min="0" max="200" step="1" class="custom-range slider-input" />
                    </div>

                    <!-- Fertilizer Slider -->
                    <div class="slider-container">
                        <div class="slider-label">
                            <span>🟤 Total Fertilizer</span>
                            <span class="text-success"><span id="val-Fertilizer">@Model.Fertilizer</span> kg/ha</span>
                        </div>
                        <input type="range" asp-for="Fertilizer" min="0" max="200" step="1" class="custom-range slider-input" />
                    </div>

                    <button type="submit" class="btn btn-agri w-100 mt-2"><i class="bi bi-cpu me-1"></i>🔮 Run Yield Predictions</button>
                </div>
            </div>

            <!-- Right Panel: Graphs & Predictions Comparison -->
            <div class="d-flex flex-column gap-4">
                
                <!-- Crop Comparison Graph Card -->
                <div class="agri-card flex-grow-1">
                    <div class="agri-card-header d-flex justify-content-between align-items-center">
                        <h4 class="m-0 text-success"><i class="bi bi-bar-chart-line me-2"></i>📊 Multi-Crop Comparison</h4>
                        <span class="text-white-50 small">R-Squared Accuracy: <strong>95.2%</strong></span>
                    </div>

                    <div class="graph-container">
                        <canvas id="yieldChart"></canvas>
                    </div>
                </div>

                <!-- Crop Recommendations Card -->
                <div class="agri-card">
                    <div class="agri-card-header">
                        <h4 class="m-0 text-success"><i class="bi bi-patch-check me-2"></i>💡 Crop Recommendation Intelligence</h4>
                    </div>

                    <div class="crop-grid">
                        @foreach(var item in Model.CropYields)
                        {
                            bool isBest = item.Key == bestCrop;
                            string emoji = item.Key switch {
                                "Rice" => "🌾",
                                "Wheat" => "🌾",
                                "Maize" => "🌽",
                                "Cotton" => "☁️",
                                _ => "🌱"
                            };
                            <div class="crop-card @(isBest ? "best-crop" : "")">
                                @if (isBest)
                                {
                                    <span class="badge bg-warning text-dark mb-2"><i class="bi bi-star-fill me-1"></i>Best Crop</span>
                                }
                                <div class="crop-emoji fs-1 mb-2">@emoji</div>
                                <div class="crop-card-name text-white">@item.Key</div>
                                <div class="crop-yield-num">@item.Value.ToString("0.00")</div>
                                <div class="text-white-50 small">Q/acre</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Update slider value displays dynamically
        document.querySelectorAll('input[type="range"]').forEach(slider => {
            const updateValue = () => {
                const id = slider.id;
                const valueSpan = document.getElementById('val-' + id);
                if (valueSpan) {
                    valueSpan.textContent = slider.value;
                }
            };
            slider.addEventListener('input', updateValue);
            slider.addEventListener('change', updateValue);
        });

        // Initialize Chart.js Double-Bar/Comparison Chart
        const ctx = document.getElementById('yieldChart').getContext('2d');
        
        // Dynamic labels & data pulled directly from C# Model dictionary
        const crops = @Html.Raw(Json.Serialize(Model.CropYields.Keys));
        const yields = @Html.Raw(Json.Serialize(Model.CropYields.Values));

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: crops,
                datasets: [{
                    label: 'Predicted Yield (Quintals/acre)',
                    data: yields,
                    backgroundColor: [
                        'rgba(16, 185, 129, 0.65)',  // Emerald Green (Rice)
                        'rgba(56, 189, 248, 0.65)',  // Neon Sky Blue (Wheat)
                        'rgba(251, 191, 36, 0.65)',  // Golden Amber (Maize)
                        'rgba(14, 165, 233, 0.65)'   // Ocean Sky Blue (Cotton)
                    ],
                    borderColor: [
                        '#10b981',
                        '#38bdf8',
                        '#fbbf24',
                        '#0ea5e9'
                    ],
                    borderWidth: 2,
                    borderRadius: 10,
                    barThickness: 60
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `Predicted Yield: ${context.parsed.y.toFixed(2)} Q/acre`;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        grid: {
                            color: 'rgba(34, 197, 94, 0.1)'
                        },
                        ticks: {
                            color: '#cbd5e1',
                            font: {
                                family: 'Outfit'
                            }
                        },
                        title: {
                            display: true,
                            text: 'Yield (Q/acre)',
                            color: '#cbd5e1'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            color: '#cbd5e1',
                            font: {
                                family: 'Outfit',
                                size: 14,
                                weight: 'bold'
                            }
                        }
                    }
                }
            }
        });
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}
